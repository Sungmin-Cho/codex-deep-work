{
  "schema_version": "1.0",
  "comment": "Migrated from claude-deep-work v6.4.0/assumptions.json. Phase C 부록 F #4: post_hoc_tool_whitelist_enforcement 신규 — Codex 가 plugin-level per-agent tools whitelist 강제 불가능 (CC frontmatter `tools:` 필드 미지원) → receipt 의 `tools_used` 필드로 사후 신호화.",
  "assumptions": [
    {
      "id": "phase_guard_blocks_edits",
      "component": "phase-guard.sh",
      "hypothesis": "Blocking code edits during non-implement phases improves final code quality",
      "evidence_signals": {
        "supporting": ["test_pass_rate_with_guard > test_pass_rate_without", "quality_score_with_guard > quality_score_without"],
        "weakening": ["high_override_rate", "zero_rework_after_override", "model_passes_all_tests_first_try", "quality_score_without_guard >= quality_score_with_guard"]
      },
      "current_enforcement": "block",
      "adjustable_levels": ["block", "warn", "off"],
      "minimum_sessions_for_evaluation": 5
    },
    {
      "id": "tdd_required_before_implement",
      "component": "phase-guard-core.js",
      "hypothesis": "Requiring RED-GREEN-REFACTOR cycle produces fewer bugs than implement-then-test",
      "evidence_signals": {
        "supporting": ["bugs_caught_in_red_phase > 0", "rework_count_strict < rework_count_relaxed", "quality_score_strict > quality_score_relaxed"],
        "weakening": ["override_rate > 50%", "zero_bugs_caught_in_red", "relaxed_mode_same_quality", "quality_score_relaxed >= quality_score_strict"]
      },
      "current_enforcement": "strict",
      "adjustable_levels": ["strict", "coaching", "relaxed", "off"],
      "minimum_sessions_for_evaluation": 10,
      "_rationale_for_10": "TDD has higher variance (strict/coaching/relaxed/spike modes) — needs more data points for meaningful comparison"
    },
    {
      "id": "research_required_before_plan",
      "component": "deep-research.md",
      "hypothesis": "Exhaustive codebase analysis before planning prevents architectural mistakes",
      "evidence_signals": {
        "supporting": ["plan_review_score_with_research > plan_review_score_without", "quality_score_with_research > quality_score_without"],
        "weakening": ["research_findings_not_referenced_in_plan", "plan_score_high_despite_shallow_research", "quality_score_skip_research >= quality_score_with_research"]
      },
      "current_enforcement": "required",
      "adjustable_levels": ["required", "recommended", "optional"],
      "minimum_sessions_for_evaluation": 5
    },
    {
      "id": "cross_model_review_improves_quality",
      "component": "review-gate.md",
      "hypothesis": "Multi-model adversarial review catches defects that single-model review misses",
      "evidence_signals": {
        "supporting": ["cross_model_found_unique_issues > 0", "plan_revision_after_cross_review", "quality_score_with_cross_review > quality_score_without"],
        "weakening": ["cross_model_agrees_with_claude_always", "zero_actionable_findings", "quality_score_without_cross_review >= quality_score_with_cross_review"]
      },
      "current_enforcement": "optional",
      "adjustable_levels": ["required", "optional", "off"],
      "minimum_sessions_for_evaluation": 5
    },
    {
      "id": "receipt_collection_ensures_evidence",
      "component": "file-tracker.sh",
      "hypothesis": "Structured JSON receipts provide verification evidence that model self-reports cannot",
      "evidence_signals": {
        "supporting": ["receipt_data_contradicts_model_claim", "test_phase_catches_receipt_gap", "quality_score_with_receipts > quality_score_without"],
        "weakening": ["receipts_always_match_model_claims", "receipt_data_never_referenced_in_test_phase", "quality_score_without_receipts >= quality_score_with_receipts"]
      },
      "current_enforcement": "required",
      "adjustable_levels": ["required", "optional"],
      "minimum_sessions_for_evaluation": 10,
      "_rationale_for_10": "Receipt utility is binary (used or not) — needs more sessions to distinguish signal from noise"
    },
    {
      "id": "evaluator_model_quality",
      "component": "deep-plan.md, deep-test.md",
      "hypothesis": "Current evaluator model catches issues effectively relative to its cost",
      "evidence_signals": {
        "supporting": ["evaluator_found_real_issues", "no_missed_issues_in_test_phase", "quality_score_higher_with_stronger_evaluator"],
        "weakening": ["evaluator_zero_findings_consistently", "missed_issues_caught_in_test", "quality_score_same_regardless_of_evaluator"]
      },
      "current_enforcement": "sonnet",
      "adjustable_levels": ["opus", "sonnet", "haiku"],
      "minimum_sessions_for_evaluation": 5
    },
    {
      "id": "post_hoc_tool_whitelist_enforcement",
      "component": "verify-receipt-core.js + file-tracker.sh + assumptions.json",
      "hypothesis": "Post-hoc receipt validation can effectively detect per-agent tool whitelist violations when plugin-level enforcement is unavailable (Codex 환경에서 CC frontmatter `tools:` 필드 미지원). receipt 의 `tools_used` (hook-derived) 와 `model_used` 를 agent 별 자연어 가이드에 명시된 allowed tool 집합과 대조하여 위반 신호화.",
      "evidence_signals": {
        "supporting": ["tools_used_violation_detected_post_hoc", "agent_attempted_disallowed_tool > 0", "violation_signal_correlates_with_quality_drop"],
        "weakening": ["tools_used_field_never_populated", "no_violations_detected_across_sessions", "post_hoc_signal_arrives_too_late_to_correct"]
      },
      "current_enforcement": "advisory",
      "adjustable_levels": ["advisory", "warn", "off"],
      "minimum_sessions_for_evaluation": 10,
      "_rationale_for_10": "post-hoc enforcement 의 효력은 violation rate × correction window 의 곱 — 두 변수의 분산이 커서 더 많은 데이터 필요. plugin-level enforcement 부재의 영향이 누적되어야 측정 가능.",
      "_codex_specific_context": "spec Section 2-5 / 3-6: agent .md 본문의 자연어 가이드 ('You may only use Read/Grep/Glob/Write tools — do not run Bash or Edit') 를 receipt 의 tools_used 와 대조. CC era 의 plugin.json `agents[].tools` 필드 부활 시 이 hypothesis 는 자동 obsolete."
    }
  ]
}
