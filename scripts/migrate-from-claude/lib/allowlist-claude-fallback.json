{
  "version": "0.1.0",
  "comment": "verify-migration.sh 의 .claude/ 리터럴 검사 시 허용되는 경로/패턴. C-A2/C2-A1 의 read-only legacy fallback 보존용.",
  "allowed_paths": [
    "hooks/scripts/lib/utils.sh",
    "hooks/scripts/lib/utils.test.sh",
    "scripts/migrate-from-claude/lib/path-mapping.json",
    "scripts/migrate-from-claude/lib/allowlist-claude-fallback.json"
  ],
  "allowed_patterns": [
    "^# Legacy CC 런타임",
    "^// .claude/ legacy fallback",
    "^# .claude/ read-only legacy",
    "validate_legacy_schema",
    "read_state_file",
    "write_state_file"
  ],
  "test_fixtures_pattern": "tests/fixtures/.*\\.claude/.*"
}
